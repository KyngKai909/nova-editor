# ── Nova environment ─────────────────────────────────────────────────────────
# Nova runs with ZERO config for local, on-device use. The variables below enable
# the OPTIONAL cloud features (auth, cloud sync, billing). Copy this file to
# .env.local and fill in the values you need.
#
# NEXT_PUBLIC_* values are exposed to the browser. Everything else is SERVER-ONLY
# and must never be prefixed with NEXT_PUBLIC_ or shipped to the client.

# ── Supabase ── auth (magic link) + cloud project sync ───────────────────────
# Apply supabase/schema.sql to your project first.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server only — bypasses RLS, never expose

# ── Stripe ── Pro/Studio billing ─────────────────────────────────────────────
# Use recurring Price IDs (price_…, NOT prod_…). Keys + prices must all be the
# same mode (test or live). Point a webhook at /api/stripe/webhook for
# checkout.session.completed + customer.subscription.created|updated|deleted.
STRIPE_SECRET_KEY=                    # server only
STRIPE_WEBHOOK_SECRET=                # server only — the webhook signing secret
STRIPE_PRO_PRICE_ID=                  # Pro recurring price
STRIPE_STUDIO_PRICE_ID=               # Studio recurring price
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # client flag that turns the billing UI on
